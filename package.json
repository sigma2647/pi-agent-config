{
  "name": "pi-agent-config",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix extensions/web-fetch && npm install --prefix extensions/subagents",
    "test:subagents": "npm --prefix extensions/subagents test && node --test extensions/subagents/test/system-prompt-mode.test.ts"
  },
  "pi": {
    "extensions": ["./extensions/index.ts", "./extensions/web-search", "./extensions/web-fetch", "./extensions/subagents"],
    "skills": ["./skills"],
    "prompts": ["./prompts"],
    "themes": ["./themes"]
  },
  "dependencies": {
    "vscode-languageserver-protocol": "^3.17.5",
    "typebox": "^1.1.38"
  }
}
